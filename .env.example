MUSHROOM_API_KEY=your_kindwise_api_key_here
MUSHROOM_API_URL=https://mushroom.kindwise.com/api/v1/identification
MUSHROOM_API_LANGUAGE=en
ENABLE_MIX_CHECK=true
MIX_CONFIDENCE_THRESHOLD=75
IDENTIFY_RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=40
TRUST_PROXY=false
APP_BASE_URL=https://orangutany.com
DATABASE_PATH=./data/amushroom.db
SESSION_TTL_DAYS=30
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://orangutany.com/api/auth/google/callback
MAX_IMAGE_BYTES=8388608
HOST=127.0.0.1
PORT=3000
